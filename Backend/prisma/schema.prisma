generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum AuthProvider {
  LOCAL
  GOOGLE
  MICROSOFT
  MOBILE
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
}

enum Designation {
  INTERN
  SOFTWARE_ENGINEER
  SENIOR_ENGINEER
  TECH_LEAD
  MANAGER
  HR
  DIRECTOR
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  PARTIAL
  LATE
  EARLY_DEPARTURE
  REGULARIZED
  HALF_DAY
  LEAVE
}

enum RegularizationType {
  MISSED_PUNCH
  TIME_CORRECTION
  ATTENDANCE_REGULARIZATION
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

enum PolicyStatus {
  DRAFT
  ACTIVE
  INACTIVE
  PENDING_APPROVAL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  LOCK
  UNLOCK
  EXPORT
  ACCESS
  CHECK_IN
  CHECK_OUT
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DepartmentType {
  IT
  SALES
  HR
  FINANCE
  MARKETING
  OPERATIONS
}

enum Status {
  PENDING
  ACTIVE
  INACTIVE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectRole {
  OWNER
  MANAGER
  MEMBER
  VIEWER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskDependencyType {
  FINISH_TO_START
  START_TO_START
  FINISH_TO_FINISH
  START_TO_FINISH
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UPDATED
  TASK_OVERDUE
  PROJECT_CREATED
  PROJECT_UPDATED
  DEADLINE_REMINDER
  DEPENDENCY_BLOCKED
}

enum CalendarViewType {
  DAY
  WEEK
  MONTH
  GANTT
}

//////////////////////////////////////////////////////
// PERMISSIONS
//////////////////////////////////////////////////////

model Permission {
  id          Int     @id @default(autoincrement())
  code        String  @unique // e.g., USERS:CREATE
  description String?

  roles     RolePermission[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  role         Role
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, permissionId])
}

//////////////////////////////////////////////////////
// COMPANY
//////////////////////////////////////////////////////

model Company {
  id       Int     @id @default(autoincrement())
  name     String
  code     String  @unique
  isActive Boolean @default(true)

  users       User[]
  departments Department[]
  attendances Attendance[]
  projects    Project[]
  employees   Employee[]
  attendancePolicies AttendancePolicy[]
  workShifts  WorkShift[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// USER (AUTH ONLY)
//////////////////////////////////////////////////////

model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  firstName       String
  lastName        String
  phone           String
  designation     String
  role            Role
  status          Status   @default(PENDING)
  password        String?
  isActive        Boolean  @default(false)
  
  // Authentication provider
  authProvider    AuthProvider @default(LOCAL)
  googleId        String?      @unique
  microsoftId     String?      @unique
  
  inviteToken     String?   @unique
  inviteExpiry    DateTime?
  tempPassword    String?
  otp             String?
  otpExpiry       DateTime?

  resetOtp        String?
  resetOtpExpiry  DateTime?

  passwordResetAllowed Boolean @default(false)

  companyId       Int?
  company         Company? @relation(fields: [companyId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee        Employee?
}

//////////////////////////////////////////////////////
// DEPARTMENT
//////////////////////////////////////////////////////

model Department {
  id   Int            @id @default(autoincrement())
  name String
  type DepartmentType

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  managerId Int?      @unique
  manager   Employee? @relation("DepartmentManager", fields: [managerId], references: [id])

  employees Employee[] @relation("DepartmentEmployees")

  projects    Project[]
  attendances Attendance[]
  leaves      Leave[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
}

//////////////////////////////////////////////////////
// EMPLOYEE (REAL PERSON)
//////////////////////////////////////////////////////

model Employee {
  id           Int @id @default(autoincrement())
  userId       Int @unique
  companyId    Int
  departmentId Int

  user       User       @relation(fields: [userId], references: [id])
  company    Company    @relation(fields: [companyId], references: [id])
  department Department @relation("DepartmentEmployees", fields: [departmentId], references: [id])

  name         String
  designation  Designation
  employeeCode String      @unique

  managerId    Int?
  manager      Employee?  @relation("ReportingManager", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subordinates Employee[] @relation("ReportingManager")

  managedDepartment Department? @relation("DepartmentManager")

  attendances    Attendance[]
  leaves         Leave[]
  approvedLeaves Leave[]      @relation("LeaveApprover")
  
  // Attendance system relationships
  regularizationRequests RegularizationRequest[]
  approvedRegularizations RegularizationRequest[] @relation("RegularizationApprover")
  createdPolicies AttendancePolicy[] @relation("PolicyCreator")
  approvedPolicies AttendancePolicy[] @relation("PolicyApprover")
  shiftAssignments ShiftAssignment[]
  
  // Audit relationships
  attendanceAudits AttendanceAuditEntry[] @relation("AttendanceAuditor")
  regularizationAudits RegularizationAuditEntry[] @relation("RegularizationAuditor")
  policyAudits PolicyAuditEntry[] @relation("PolicyAuditor")

  ownedProjects  Project[] @relation("ProjectOwner")
  memberProjects Project[] @relation("ProjectMembers")

  assignedTasks Task[] @relation("TaskAssignee")
  createdTasks  Task[] @relation("TaskCreator")
  comments      TaskComment[] @relation("CommentAuthor")
  timeEntries   TaskTimeEntry[] @relation("TimeEntries")
  attachments   TaskAttachment[] @relation("TaskAttachments")
  projectRoles  ProjectMember[] @relation("ProjectMemberRoles")
  notifications NotificationRecipient[]
  createdNotifications Notification[] @relation("NotificationCreator")
  organizedEvents CalendarEvent[] @relation("EventOrganizer")
  eventAttendances CalendarEventAttendee[] @relation("EventAttendee")
  generatedReports ProjectReport[] @relation("ReportGenerator")
  taskReports TaskReport[] @relation("TaskReporter")
  createdTemplates ProjectTemplate[] @relation("TemplateCreator")
  createdAutomations AutomationRule[] @relation("AutomationCreator")

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// ATTENDANCE SYSTEM
//////////////////////////////////////////////////////

model Attendance {
  id Int @id @default(autoincrement())

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])

  date     DateTime
  status   AttendanceStatus
  checkIn  DateTime?
  checkOut DateTime?
  
  // Enhanced fields for enterprise attendance
  location          Json?     // GeoLocation data
  deviceInfo        Json?     // Device information
  timeSlots         Json?     // Array of check-in/check-out time slots for multiple entries
  workHours         Float?    // Calculated work hours
  overtime          Float?    // Overtime hours
  breakTime         Float?    // Break time in hours
  isLocked          Boolean   @default(false)
  
  // Manual corrections
  isManuallyEdited  Boolean   @default(false)
  editReason        String?
  editedBy          Int?
  editedAt          DateTime?
  
  // Approval workflow
  requiresApproval  Boolean   @default(false)
  approvedBy        Int?
  approvedAt        DateTime?
  
  regularizationRequests RegularizationRequest[]
  auditEntries          AttendanceAuditEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date])
}

model RegularizationRequest {
  id String @id @default(cuid())
  
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  
  attendanceId Int
  attendance   Attendance @relation(fields: [attendanceId], references: [id])
  
  requestType RegularizationType
  reason      String
  
  // Proposed changes
  proposedCheckIn  DateTime?
  proposedCheckOut DateTime?
  proposedStatus   AttendanceStatus?
  
  status RequestStatus @default(PENDING)
  
  // Approval workflow
  submittedAt   DateTime @default(now())
  approvedBy    Int?
  approver      Employee? @relation("RegularizationApprover", fields: [approvedBy], references: [id])
  approvedAt    DateTime?
  rejectionReason String?
  
  // SLA tracking
  slaBreached   Boolean @default(false)
  escalatedTo   Int?
  escalatedAt   DateTime?
  
  auditEntries  RegularizationAuditEntry[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AttendancePolicy {
  id String @id @default(cuid())
  
  companyId Int
  company   Company @relation(fields: [companyId], references: [id])
  
  policyName    String
  description   String?
  
  // Working hours configuration
  standardHours     Float @default(8.0)
  flexibleHours     Boolean @default(false)
  coreHoursStart    String? // "09:00"
  coreHoursEnd      String? // "17:00"
  
  // Grace periods (in minutes)
  checkInGrace      Int @default(15)
  checkOutGrace     Int @default(15)
  lunchBreakGrace   Int @default(30)
  
  // Overtime rules
  overtimeEnabled   Boolean @default(true)
  overtimeRate      Float @default(1.5)
  maxOvertimeHours  Float @default(4.0)
  
  // Remote work rules
  remoteWorkEnabled Boolean @default(false)
  locationValidation Boolean @default(true)
  allowedLocations  Json? // Array of allowed locations
  
  // Holiday calendar
  holidays          Json? // Array of holiday dates
  
  // Policy lifecycle
  effectiveFrom DateTime
  effectiveTo   DateTime?
  status        PolicyStatus @default(DRAFT)
  
  createdBy     Int
  creator       Employee @relation("PolicyCreator", fields: [createdBy], references: [id])
  approvedBy    Int?
  approver      Employee? @relation("PolicyApprover", fields: [approvedBy], references: [id])
  
  auditEntries  PolicyAuditEntry[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkShift {
  id String @id @default(cuid())
  
  companyId Int
  company   Company @relation(fields: [companyId], references: [id])
  
  name        String
  description String?
  
  startTime   String // "09:00"
  endTime     String // "17:00"
  
  // Days of week (0 = Sunday, 6 = Saturday)
  workingDays Json // [1, 2, 3, 4, 5]
  
  isActive Boolean @default(true)
  
  employees ShiftAssignment[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShiftAssignment {
  id String @id @default(cuid())
  
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  
  shiftId String
  shift   WorkShift @relation(fields: [shiftId], references: [id])
  
  effectiveFrom DateTime
  effectiveTo   DateTime?
  
  isActive Boolean @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([employeeId, shiftId, effectiveFrom])
}

//////////////////////////////////////////////////////
// AUDIT SYSTEM
//////////////////////////////////////////////////////

model AttendanceAuditEntry {
  id String @id @default(cuid())
  
  attendanceId Int
  attendance   Attendance @relation(fields: [attendanceId], references: [id])
  
  action       AuditAction
  performedBy  Int
  performer    Employee @relation("AttendanceAuditor", fields: [performedBy], references: [id])
  
  performedAt  DateTime @default(now())
  ipAddress    String?
  userAgent    String?
  
  oldValues    Json?
  newValues    Json?
  reason       String?
  
  sessionId    String?
  isImmutable  Boolean @default(true)
  
  createdAt DateTime @default(now())
}

model RegularizationAuditEntry {
  id String @id @default(cuid())
  
  requestId String
  request   RegularizationRequest @relation(fields: [requestId], references: [id])
  
  action       AuditAction
  performedBy  Int
  performer    Employee @relation("RegularizationAuditor", fields: [performedBy], references: [id])
  
  performedAt  DateTime @default(now())
  ipAddress    String?
  userAgent    String?
  
  oldValues    Json?
  newValues    Json?
  reason       String?
  
  sessionId    String?
  isImmutable  Boolean @default(true)
  
  createdAt DateTime @default(now())
}

model PolicyAuditEntry {
  id String @id @default(cuid())
  
  policyId String
  policy   AttendancePolicy @relation(fields: [policyId], references: [id])
  
  action       AuditAction
  performedBy  Int
  performer    Employee @relation("PolicyAuditor", fields: [performedBy], references: [id])
  
  performedAt  DateTime @default(now())
  ipAddress    String?
  userAgent    String?
  
  oldValues    Json?
  newValues    Json?
  reason       String?
  
  sessionId    String?
  isImmutable  Boolean @default(true)
  
  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// LEAVE
//////////////////////////////////////////////////////

model Leave {
  id Int @id @default(autoincrement())

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])

  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])

  type   LeaveType
  status LeaveStatus @default(PENDING)
  reason String?

  startDate DateTime
  endDate   DateTime

  approvedById Int?
  approvedBy   Employee? @relation("LeaveApprover", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// PROJECT
//////////////////////////////////////////////////////

model Project {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  code        String? @unique // Project code for easy identification

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])

  ownerId Int
  owner   Employee @relation("ProjectOwner", fields: [ownerId], references: [id])

  status ProjectStatus @default(PLANNING)
  
  // Project timeline
  startDate DateTime?
  endDate   DateTime?
  
  // Budget and resource management
  budget      Decimal?
  actualCost  Decimal?
  
  // Progress tracking
  progressPercentage Int @default(0)
  
  members Employee[] @relation("ProjectMembers")
  tasks   Task[]
  projectRoles ProjectMember[]
  milestones   Milestone[]
  reports      ProjectReport[] @relation("ProjectReports")

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectMember {
  id        Int         @id @default(autoincrement())
  projectId Int
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  employeeId Int
  employee   Employee    @relation("ProjectMemberRoles", fields: [employeeId], references: [id])
  
  role       ProjectRole @default(MEMBER)
  joinedAt   DateTime    @default(now())
  leftAt     DateTime?
  
  isActive   Boolean     @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([projectId, employeeId])
}

model Milestone {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  dueDate     DateTime
  completedAt DateTime?
  
  isCompleted Boolean  @default(false)
  
  tasks       Task[]   @relation("MilestoneTasks")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// TASK MANAGEMENT
//////////////////////////////////////////////////////

model Task {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  code        String? // Task code for easy identification
  
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  milestoneId Int?
  milestone   Milestone? @relation("MilestoneTasks", fields: [milestoneId], references: [id])
  
  assignedToId Int?
  assignedTo   Employee? @relation("TaskAssignee", fields: [assignedToId], references: [id])
  
  createdById Int
  createdBy   Employee @relation("TaskCreator", fields: [createdById], references: [id])
  
  status   TaskStatus   @default(TODO)
  priority TaskPriority @default(MEDIUM)
  
  // Timeline management
  dueDate    DateTime?
  startDate  DateTime?
  completedAt DateTime?
  
  // Time tracking
  estimatedHours Int?
  actualHours    Int?
  
  // Progress tracking
  progressPercentage Int @default(0)
  
  // Task hierarchy
  parentTaskId Int?
  parentTask   Task? @relation("TaskHierarchy", fields: [parentTaskId], references: [id])
  subTasks     Task[] @relation("TaskHierarchy")
  
  // Dependencies
  dependencies     TaskDependency[] @relation("DependentTask")
  dependents       TaskDependency[] @relation("PredecessorTask")
  
  comments TaskComment[]
  timeEntries TaskTimeEntry[]
  attachments TaskAttachment[]
  reports     TaskReport[] @relation("TaskReports")
  
  isActive Boolean @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskDependency {
  id Int @id @default(autoincrement())
  
  predecessorTaskId Int
  predecessorTask   Task @relation("PredecessorTask", fields: [predecessorTaskId], references: [id], onDelete: Cascade)
  
  dependentTaskId Int
  dependentTask   Task @relation("DependentTask", fields: [dependentTaskId], references: [id], onDelete: Cascade)
  
  type TaskDependencyType @default(FINISH_TO_START)
  lag  Int                @default(0) // Lag time in hours
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([predecessorTaskId, dependentTaskId])
}

model TaskComment {
  id      Int    @id @default(autoincrement())
  content String
  
  taskId Int
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  authorId Int
  author   Employee @relation("CommentAuthor", fields: [authorId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskTimeEntry {
  id          Int      @id @default(autoincrement())
  description String?
  
  taskId Int
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  employeeId Int
  employee   Employee @relation("TimeEntries", fields: [employeeId], references: [id])
  
  startTime DateTime
  endTime   DateTime?
  duration  Int?      // Duration in minutes
  
  isActive Boolean @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskAttachment {
  id       Int    @id @default(autoincrement())
  fileName String
  filePath String
  fileSize Int?
  mimeType String?
  
  taskId Int
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  uploadedById Int
  uploadedBy   Employee @relation("TaskAttachments", fields: [uploadedById], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// NOTIFICATION SYSTEM
//////////////////////////////////////////////////////

model Notification {
  id      Int              @id @default(autoincrement())
  title   String
  message String
  type    NotificationType
  
  // Reference data (JSON for flexibility)
  referenceId   Int?
  referenceType String? // 'task', 'project', 'milestone'
  metadata      Json?
  
  createdById Int
  createdBy   Employee @relation("NotificationCreator", fields: [createdById], references: [id])
  
  recipients NotificationRecipient[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationRecipient {
  id Int @id @default(autoincrement())
  
  notificationId Int
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  
  recipientId Int
  recipient   Employee @relation(fields: [recipientId], references: [id])
  
  isRead   Boolean   @default(false)
  readAt   DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([notificationId, recipientId])
}

//////////////////////////////////////////////////////
// CALENDAR & SCHEDULING
//////////////////////////////////////////////////////

model CalendarEvent {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  
  startDateTime DateTime
  endDateTime   DateTime
  isAllDay      Boolean @default(false)
  
  // Event type and reference
  eventType     String // 'task', 'project', 'milestone', 'meeting'
  referenceId   Int?
  
  // Recurrence
  isRecurring   Boolean @default(false)
  recurrenceRule String? // RRULE format
  
  // Attendees
  organizerId Int
  organizer   Employee @relation("EventOrganizer", fields: [organizerId], references: [id])
  
  attendees CalendarEventAttendee[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CalendarEventAttendee {
  id Int @id @default(autoincrement())
  
  eventId Int
  event   CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  attendeeId Int
  attendee   Employee @relation("EventAttendee", fields: [attendeeId], references: [id])
  
  status String @default("pending") // pending, accepted, declined, tentative
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([eventId, attendeeId])
}

//////////////////////////////////////////////////////
// REPORTING & ANALYTICS
//////////////////////////////////////////////////////

model ProjectReport {
  id Int @id @default(autoincrement())
  
  projectId Int
  project   Project @relation("ProjectReports", fields: [projectId], references: [id])
  
  reportType String // 'weekly', 'monthly', 'milestone', 'completion'
  
  // Metrics
  totalTasks       Int
  completedTasks   Int
  overdueTasks     Int
  totalHours       Int
  actualHours      Int
  budgetUsed       Decimal?
  
  // Progress data (JSON for flexibility)
  progressData Json?
  
  generatedById Int
  generatedBy   Employee @relation("ReportGenerator", fields: [generatedById], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskReport {
  id Int @id @default(autoincrement())
  
  taskId Int
  task   Task @relation("TaskReports", fields: [taskId], references: [id])
  
  reportDate DateTime @default(now())
  
  // Status at time of report
  statusSnapshot   TaskStatus
  progressSnapshot Int
  hoursSpent       Int?
  
  // Comments/notes
  notes String?
  
  reportedById Int
  reportedBy   Employee @relation("TaskReporter", fields: [reportedById], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// TEMPLATES & AUTOMATION
//////////////////////////////////////////////////////

model ProjectTemplate {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  
  // Template configuration (JSON)
  templateData Json
  
  createdById Int
  createdBy   Employee @relation("TemplateCreator", fields: [createdById], references: [id])
  
  isActive Boolean @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AutomationRule {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  
  // Trigger conditions
  triggerType   String // 'task_status_change', 'due_date_approaching', 'project_milestone'
  triggerConfig Json
  
  // Actions to perform
  actionType   String // 'send_notification', 'assign_task', 'update_status'
  actionConfig Json
  
  isActive Boolean @default(true)
  
  createdById Int
  createdBy   Employee @relation("AutomationCreator", fields: [createdById], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}